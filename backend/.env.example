# Telegram
BOT_TOKEN=your_telegram_bot_token
BOT_MODE=polling
WEBHOOK_DOMAIN=https://your-domain.com

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
