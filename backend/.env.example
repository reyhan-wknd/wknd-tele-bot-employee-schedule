# Database
DATABASE_URL=mysql://user:password@localhost:3306/tele_sso

# App
PORT=3000
JWT_SECRET=your_jwt_secret_for_state_tokens
FRONTEND_URL=http://localhost:8080

# Supabase
SUPABASE_KEY=your_supabase_anon_key